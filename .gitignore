.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
workspace/raw/**
workspace/text/**
workspace/documents/**
workspace/attachments/**
workspace/observations/**
workspace/index/**
workspace/audit/**
workspace/logs/**
workspace/events/**
exports/latest/**
!workspace/raw/.gitkeep
!workspace/text/.gitkeep
!workspace/documents/.gitkeep
!workspace/attachments/.gitkeep
!workspace/observations/.gitkeep
!workspace/index/.gitkeep
!workspace/audit/.gitkeep
!workspace/logs/.gitkeep
!workspace/events/.gitkeep
!exports/latest/.gitkeep
